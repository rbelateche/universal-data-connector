# ─── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://udc:udc_secret@localhost:5432/udc_demo

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional (defaults shown) ────────────────────────────────────────────────
# Claude model used for schema inference
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Path to the DuckDB file for local storage
DUCKDB_PATH=./data/udc.duckdb

# Static API key protecting the FastAPI backend
API_KEY=change-me-in-production

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Application environment: development | production
APP_ENV=development
